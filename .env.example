# Credenciais do Postgres usadas pelo docker-compose (serviço `db`).
# Copie para `.env` e ajuste se quiser valores diferentes dos defaults abaixo.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=central

# Credenciais do MinIO usadas pelo docker-compose (serviço `minio`).
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
