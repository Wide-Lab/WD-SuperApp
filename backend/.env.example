DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/central
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:5173"]

# Gerar com:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
AUTH_JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
AUTH_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
AUTH_TOKEN_TTL_SECONDS=604800
AUTH_COOKIE_DOMAIN=".widelab.com.br"

# Usuário criado automaticamente na subida da aplicação (opcional).
# Se AUTH_DEFAULT_USER_EMAIL ou AUTH_DEFAULT_USER_PASSWORD estiverem vazios, a criação é pulada.
AUTH_DEFAULT_USER_EMAIL=
AUTH_DEFAULT_USER_NAME=
AUTH_DEFAULT_USER_PASSWORD=

# MinIO / S3 — armazenamento das imagens de aplicações.
# Endpoint interno: como o backend fala com o MinIO dentro da rede docker
# (fora do compose, ex. rodando o backend standalone, use http://localhost:9000).
APPLICATIONS_STORAGE_ENDPOINT_URL=http://minio:9000
APPLICATIONS_STORAGE_ACCESS_KEY=minioadmin
APPLICATIONS_STORAGE_SECRET_KEY=minioadmin
APPLICATIONS_BUCKET_NAME=applications

# Prefixo público usado para montar o campo `image` de GET /api/apps.
# Vazio ou relativo (default) produz /media/<key>, servido pelo nginx
# (ver nginx/default.conf). Preencher com URL absoluta só se as imagens
# passarem a vir de outra origem (ex. CDN) no futuro.
APPLICATIONS_MEDIA_BASE_URL=/media
